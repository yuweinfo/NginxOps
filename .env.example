# =====================================================
# Nginx Panel 环境配置
# 复制此文件为 .env 并修改配置
# =====================================================

# ==================== 数据库配置 ====================
# 是否使用外部数据库 (true/false)
USE_EXTERNAL_DB=false

# 数据库连接配置 (使用内部数据库时无需修改)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=nginxops
DB_USER=postgres
DB_PASSWORD=your-strong-password-here

# ==================== JWT配置 ====================
# JWT密钥 (至少256位，请修改为随机字符串)
JWT_SECRET=nginxops-secret-key-must-be-at-least-256-bits-long-for-hs256-algorithm

# ==================== 端口配置 ====================
# 管理面板端口
ADMIN_PORT=8899
# 业务代理端口
HTTP_PORT=80
HTTPS_PORT=443

# ==================== 数据目录 ====================
# 持久化数据目录 (默认为当前目录下的data文件夹)
DATA_PATH=./data

# ==================== 数据库迁移配置 ====================
# 迁移任务最大重试次数
MAX_RETRIES=30
# 重试间隔(秒)
RETRY_INTERVAL=5

# ==================== 时区配置 ====================
TZ=Asia/Shanghai

# =====================================================
# 部署说明:
# 
# 1. 首次部署:
#    cp .env.example .env
#    # 修改 .env 中的配置
#    docker-compose up -d
#
# 2. 使用外部数据库:
#    USE_EXTERNAL_DB=true
#    DB_HOST=your-db-host
#    DB_USER=your-username
#    DB_PASSWORD=your-password
#
# 3. 数据持久化:
#    所有数据存储在 DATA_PATH 目录下
#    只需备份此目录即可
#
# 4. 访问管理面板:
#    http://your-server:8899
# =====================================================
